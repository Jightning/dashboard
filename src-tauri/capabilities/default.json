{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Main window capabilities: DB, provider HTTP, attachments FS, key store, dialogs",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "sql:default",
        "sql:allow-execute",
        "sql:allow-select",
        "store:default",
        "dialog:default",
        {
            "identifier": "http:default",
            "allow": [
                { "url": "https://generativelanguage.googleapis.com/*" },
                { "url": "https://api.anthropic.com/*" },
                { "url": "https://api.openai.com/*" },
                { "url": "http://localhost:11434/*" },
                { "url": "https://*/*" }
            ]
        },
        "fs:default",
        "fs:allow-mkdir",
        "fs:allow-write-file",
        "fs:allow-read-file",
        "fs:allow-remove",
        "fs:allow-exists",
        {
            "identifier": "fs:scope",
            "allow": [{ "path": "$APPDATA" }, { "path": "$APPDATA/**" }]
        }
    ]
}
