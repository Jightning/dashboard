{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Personal Dashboard",
    "version": "0.1.0",
    "identifier": "com.jmvaz.dashboard",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Personal Dashboard",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600
            }
        ],
        "security": {
            "csp": {
                "default-src": "'self'",
                "connect-src": "'self' ipc: http://ipc.localhost http://localhost:11434",
                "img-src": "'self' asset: http://asset.localhost data: blob:",
                "media-src": "'self' blob:",
                "style-src": "'self' 'unsafe-inline'"
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": []
    }
}
